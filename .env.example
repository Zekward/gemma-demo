# Copy to .env.local and fill in. The app runs WITHOUT keys in "simulated" mode
# (clearly flagged in the UI). Add keys to make the side-by-side fully live.

# --- Cerebras (the fast side) ---
CEREBRAS_API_KEY=
# Default base URL is https://api.cerebras.ai/v1
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Set to the exact Gemma model id Cerebras exposes to you, e.g. gemma-3-27b-it
CEREBRAS_MODEL=gemma-3-27b-it

# --- GPU provider (the comparison side) — any OpenAI-compatible host of the SAME Gemma ---
# Together example shown; Fireworks/others work too. Use the same model for an honest A/B.
GPU_API_KEY=
GPU_BASE_URL=https://api.together.xyz/v1
GPU_MODEL=google/gemma-3-27b-it
GPU_LABEL=GPU (Together)

# --- Lean (formal verification) ---
# Path to the lean binary. Defaults to ~/.elan/bin/lean (installed by elan).
# LEAN_BIN=/Users/you/.elan/bin/lean
