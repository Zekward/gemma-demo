# Copy to .env.local and fill in. The app runs WITHOUT keys in "simulated" mode
# (clearly flagged in the UI). Add keys to make each side fully live — the two
# sides are independent, so you can run Cerebras live while the GPU side stays
# simulated.

# --- Cerebras (the fast side) ---
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Models available on Cerebras (this hackathon): gemma-4-31b, gpt-oss-120b, zai-glm-4.7
CEREBRAS_MODEL=gemma-4-31b

# --- GPU / conventional-cloud comparison side — any OpenAI-compatible Gemma host ---
# RECOMMENDED FREE OPTION: Google AI Studio (free key at https://aistudio.google.com/apikey).
# Serves canonical Gemma; note Google uses TPUs, so label it accurately.
GPU_API_KEY=
GPU_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GPU_MODEL=gemma-3-27b-it
GPU_LABEL=Google AI Studio
#
# Other options (swap the three values above):
#   Together (paid credits):  https://api.together.xyz/v1            | google/gemma-3-27b-it
#   OpenRouter (free tier):   https://openrouter.ai/api/v1          | google/gemma-3-27b-it:free
#   Fireworks:                https://api.fireworks.ai/inference/v1 | accounts/fireworks/models/gemma-3-27b-it

# --- Lean (formal verification) ---
# Path to the lean binary. Defaults to ~/.elan/bin/lean (installed by elan).
# LEAN_BIN=/Users/you/.elan/bin/lean
